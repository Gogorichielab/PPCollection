<!DOCTYPE html>
<html lang="en" data-theme="<%= theme || 'dark' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- SEO -->
  <meta name="description" content="Pew Pew Collection — a self-hosted, privacy-first firearm inventory manager. Runs locally. Your data stays yours.">
  <meta name="robots" content="index, follow">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Pew Pew Collection">
  <meta property="og:title" content="<%= pageTitle ? pageTitle + ' — Pew Pew Collection' : 'Pew Pew Collection' %>">
  <meta property="og:description" content="A self-hosted, privacy-first firearm inventory manager. Runs locally. Your data stays yours.">
  <meta property="og:url" content="">
  <!-- TODO: add /static/img/og-image.png (1200x630) and enable the image tags below. -->
  <!-- <meta property="og:image" content="/static/img/og-image.png"> -->

  <!-- Twitter / X card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= pageTitle ? pageTitle + ' — Pew Pew Collection' : 'Pew Pew Collection' %>">
  <meta name="twitter:description" content="A self-hosted, privacy-first firearm inventory manager. Runs locally. Your data stays yours.">
  <!-- <meta name="twitter:image" content="/static/img/og-image.png"> -->
  <title><%= pageTitle ? pageTitle + ' — ' : '' %>Pew Pew Collection</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/styles.css">
</head>
<body class="<%= typeof pageClass !== 'undefined' ? pageClass : '' %>">
  <% if (csrfToken) { %>
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" id="csrf-token">
  <% } %>
  <% const isHome = currentPath === '/' || currentPath === '/home'; %>
  <% const isInventory = currentPath && currentPath.startsWith('/firearms') && !currentPath.startsWith('/firearms/new'); %>
  <% const isAddFirearm = currentPath === '/firearms/new'; %>
  <% const isProfile = currentPath && currentPath.startsWith('/profile'); %>
  <header class="topbar">
    <div class="container">
      <div class="brand-group">
        <h1><a href="/">Pew Pew Collection</a></h1>
        <nav class="primary-nav" aria-label="Primary">
          <a
            class="nav-link <%= isHome ? 'active' : '' %>"
            href="/"
            <%= isHome ? 'aria-current="page"' : '' %>
          >Home</a>
          <a
            class="nav-link <%= isInventory ? 'active' : '' %>"
            href="/firearms"
            <%= isInventory ? 'aria-current="page"' : '' %>
          >Inventory</a>
          <a
            class="nav-link <%= isAddFirearm ? 'active' : '' %>"
            href="/firearms/new"
            <%= isAddFirearm ? 'aria-current="page"' : '' %>
          >Add Firearm</a>
          <a
            class="nav-link <%= isProfile ? 'active' : '' %>"
            href="/profile"
            <%= isProfile ? 'aria-current="page"' : '' %>
          >Profile</a>
          <a
            class="nav-link"
            href="https://github.com/Gogorichielab/PPCollection/issues"
            target="_blank"
            rel="noopener noreferrer"
          >Report Issue</a>
        </nav>
      </div>
      <div class="header-controls">
        <button id="theme-toggle" class="btn btn-secondary" title="Toggle theme">
          <span class="theme-icon">☀️</span>
        </button>
        <% if (user) { %>
        <form method="post" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-secondary" type="submit">Logout (<%= user.username %>)</button>
        </form>
        <% } %>
      </div>
    </div>
  </header>
  <main class="container">
    <%- body %>
  </main>
  <script src="/static/js/theme.js"></script>
  <% if (typeof pageScript !== 'undefined' && pageScript) { %>
  <script src="<%= pageScript %>"></script>
  <% } %>
  <% if (typeof pageScripts !== 'undefined' && Array.isArray(pageScripts)) { %>
    <% pageScripts.forEach((scriptPath) => { %>
  <script src="<%= scriptPath %>"></script>
    <% }) %>
  <% } %>
</body>
</html>
