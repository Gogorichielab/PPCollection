<section class="app-hero home-hero" aria-label="Collection overview">
  <p class="home-hero-tag label-caps">Welcome back, <%= username %></p>
  <h2 class="home-hero-title page-title">Collection Overview</h2>
  <p class="home-hero-subtitle meta">Everything in one place. Here is your latest activity and a snapshot of the collection.</p>

  <div class="home-stats" role="list" aria-label="Collection statistics">
    <div class="home-stat stat-card" role="listitem">
      <span class="home-stat-value stat-value mono"><%= stats.totalFirearms %></span>
      <span class="home-stat-label stat-label label-caps">Firearms</span>
    </div>
    <div class="home-stat stat-card" role="listitem">
      <span class="home-stat-value stat-value mono"><%= stats.thisMonth %></span>
      <span class="home-stat-label stat-label label-caps">This month</span>
    </div>
    <div class="home-stat stat-card" role="listitem">
      <span class="home-stat-value stat-value mono"><%= stats.categories %></span>
      <span class="home-stat-label stat-label label-caps">Categories</span>
    </div>
    <div class="home-stat stat-card" role="listitem">
      <span class="home-stat-value home-stat-value-accent stat-value mono"><%= stats.lastUpdateDays %></span>
      <span class="home-stat-label stat-label label-caps">Last update</span>
    </div>
    <div class="home-stat stat-card" role="listitem">
      <span class="home-stat-value stat-value mono <%= stats.dueForCleaning > 0 ? 'home-stat-value-accent' : '' %>"><%= stats.dueForCleaning %></span>
      <span class="home-stat-label stat-label label-caps">Due for cleaning</span>
    </div>
  </div>
</section>

<section class="home-activity-section" aria-label="Recent activity">
  <article class="card home-card panel">
    <header class="home-card-header">
      <p class="label-caps">Activity</p>
      <h3>Recent Activity</h3>
      <a class="meta" href="/firearms">View all →</a>
    </header>
    <div class="home-card-body">
      <% if (!recentActivity.length) { %>
        <p class="muted-text meta">No activity yet. Add your first firearm to get started.</p>
      <% } else { %>
        <% recentActivity.forEach((activity) => { %>
          <div class="activity-row">
            <span class="activity-dot <%= activity.isRecent ? 'is-recent' : '' %>" aria-hidden="true"></span>
            <span class="activity-description">
              <% if (activity.isRecent) { %><span class="visually-hidden">New activity. </span><% } %>
              <%= activity.description %>
              <% if (activity.isRecent) { %><span class="activity-new-badge" aria-hidden="true">New</span><% } %>
            </span>
            <span class="activity-time meta"><%= activity.timeAgo %></span>
          </div>
        <% }) %>
      <% } %>
    </div>
  </article>
</section>

<% if (typeof cleaningDue !== 'undefined' && cleaningDue && cleaningDue.length) { %>
<section class="home-activity-section" aria-label="Cleaning due">
  <article class="card home-card panel">
    <header class="home-card-header">
      <p class="label-caps">Maintenance</p>
      <h3>Due for Cleaning</h3>
    </header>
    <div class="home-card-body">
      <% cleaningDue.forEach((entry) => { %>
        <div class="activity-row">
          <span class="activity-dot is-recent" aria-hidden="true"></span>
          <a class="activity-description" href="/firearms/<%= entry.id %>"><%= entry.label %></a>
          <span class="activity-time meta"><%= entry.reason %></span>
        </div>
      <% }) %>
    </div>
  </article>
</section>
<% } %>

<section class="home-chart-row" aria-label="Dashboard charts">
  <article class="card home-card panel">
    <header class="home-card-header">
      <p class="label-caps">Value</p>
      <h3>Collection Value by Year</h3>
    </header>
    <div class="home-card-body home-chart-card-body">
      <% if (!charts.valueByYear.length) { %>
        <p class="muted-text home-chart-empty meta">No purchase data yet. <a href="/firearms/new">Add a firearm</a> with purchase date and price to visualize value over time.</p>
      <% } else { %>
        <div class="home-chart-wrap">
          <canvas id="collection-value-chart" aria-label="Collection purchase value by year" role="img"></canvas>
        </div>
      <% } %>
    </div>
  </article>

  <article class="card home-card panel">
    <header class="home-card-header">
      <p class="label-caps">Breakdown</p>
      <h3>Collection by Type</h3>
    </header>
    <div class="home-card-body home-chart-card-body">
      <% if (!charts.typeBreakdown.length) { %>
        <p class="muted-text home-chart-empty meta">No firearms yet. <a href="/firearms/new">Add your first firearm</a> to see your type breakdown.</p>
      <% } else { %>
        <div class="home-chart-wrap">
          <canvas id="collection-type-chart" aria-label="Collection breakdown by firearm type" role="img"></canvas>
        </div>
      <% } %>
    </div>
  </article>
</section>

<script type="application/json" id="home-charts-data"><%- JSON.stringify(charts).replace(/</g, '\\u003c') %></script>
