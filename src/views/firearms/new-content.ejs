  <div class="page-header">
  <span class="eyebrow">Firearms</span>
  <h1>New Firearm</h1>
  <p class="page-subtitle">Fill in the details below to add a new firearm to your collection.</p>
</div>
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  <form method="post" action="/firearms" class="form grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <%- include('./_form', { item, fieldErrors: fieldErrors || {} }) %>
    <div class="form-actions">
      <a class="btn btn-secondary" href="/firearms">Cancel</a>
      <button class="btn" type="submit">Create</button>
    </div>
  </form>
