  <section class="app-hero">
    <p class="eyebrow label-caps">Firearm Details</p>
    <h2 class="page-title"><%= item.make %> <%= item.model %></h2>
    <div class="badge-row">
      <% function getStatusBadgeClass(value) {
        const normalized = String(value || '').trim().toLowerCase();
        if (normalized === 'active') return 'badge-active';
        if (normalized === 'sold') return 'badge-sold';
        if (normalized === 'under repair' || normalized === 'repair' || normalized === 'maintenance') return 'badge-repair';
        if (normalized === 'lost' || normalized === 'lost/stolen' || normalized === 'stolen') return 'badge-lost';
        return 'badge-accent';
      } %>
      <% const statusBadgeClass = getStatusBadgeClass(item.status); %>
      <span class="badge <%= statusBadgeClass %>"><%= item.status || 'Unknown Status' %></span>
      <span class="badge badge-outline label-caps"><%= item.firearm_type || 'Unknown Type' %></span>
    </div>
  </section>

  <div class="action-bar page-section panel">
    <div class="title-group">
      <p class="label-caps">Firearm</p>
      <h3 class="card-title">Actions</h3>
      <small class="meta">Review, update, duplicate, print, or delete this entry.</small>
    </div>
    <div class="action-bar-actions">
      <a class="btn btn-primary" href="/firearms/<%= item.id %>/edit">Edit</a>
      <form id="delete-form" method="post" action="/firearms/<%= item.id %>/delete" class="form-inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-danger" type="button" data-delete-open>Delete</button>
      </form>
    </div>
  </div>

  <div class="item-toolbar">
    <a class="btn btn-secondary" href="/firearms">← Back to list</a>
    <a class="btn btn-secondary" href="/firearms/<%= item.id %>/duplicate">Duplicate</a>
    <button class="btn btn-secondary" type="button" onclick="window.print()">Print / Export</button>
  </div>

  <div class="detail-grid">
    <section class="detail-card panel">
      <p class="section-header label-caps">Profile</p>
      <dl class="details">
        <dt class="label-caps">Serial</dt><dd class="mono"><%= item.serial || '-' %></dd>
        <dt class="label-caps">Caliber</dt><dd class="mono"><%= item.caliber || '-' %></dd>
        <dt class="label-caps">Location</dt><dd><%= item.location || '-' %></dd>
      </dl>
    </section>

    <section class="detail-card panel">
      <p class="section-header label-caps">Ownership</p>
      <dl class="details">
        <dt class="label-caps">Status</dt><dd><span class="badge <%= statusBadgeClass %>"><%= item.status || '-' %></span></dd>
        <dt class="label-caps">Gun Warranty</dt><dd><%= item.gun_warranty === 1 ? 'Yes' : (item.gun_warranty === 0 ? 'No' : '-') %></dd>
      </dl>
    </section>

    <section class="detail-card panel">
      <p class="section-header label-caps">Purchase</p>
      <dl class="details">
        <dt class="label-caps">Purchase Date</dt><dd class="mono"><%= item.purchase_date || '-' %></dd>
        <dt class="label-caps">Purchase Price</dt><dd class="mono"><%= (item.purchase_price !== null && item.purchase_price !== undefined) ? ('$' + item.purchase_price) : '-' %></dd>
        <dt class="label-caps">Purchase Condition</dt><dd><%= item.condition || '-' %></dd>
      </dl>
    </section>

    <% function isDispositionStatus(value) {
      const n = String(value || '').trim().toLowerCase();
      return n === 'sold' || n === 'lost/stolen' || n === 'lost' || n === 'stolen';
    } %>
    <% if (isDispositionStatus(item.status)) { %>
      <section class="detail-card panel">
        <p class="section-header label-caps">Disposition</p>
        <dl class="details">
          <dt class="label-caps">Transferred To</dt><dd><%= item.disposition_name || '-' %></dd>
          <dt class="label-caps">Address</dt><dd><%= item.disposition_address || '-' %></dd>
          <dt class="label-caps">Date</dt><dd class="mono"><%= item.disposition_date || '-' %></dd>
          <dt class="label-caps">Reason</dt><dd><%= item.disposition_reason || '-' %></dd>
        </dl>
      </section>
    <% } %>

    <section class="detail-card detail-card-full panel">
      <p class="section-header label-caps">Notes</p>
      <pre class="notes mono"><%= item.notes || '-' %></pre>
    </section>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-modal" class="modal-overlay" data-delete-modal>
    <div class="modal-dialog">
      <div class="modal-header">
        <h3 class="modal-title">Confirm Delete</h3>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to delete <strong><%= item.make %> <%= item.model %></strong>?</p>
        <p class="modal-warning">This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" type="button" data-delete-cancel>Cancel</button>
        <button class="btn btn-danger" type="button" data-delete-confirm>Delete</button>
      </div>
    </div>
  </div>
